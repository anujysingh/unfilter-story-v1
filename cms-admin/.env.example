# cms-admin (React + Vite) environment variables
# Copy to `.env` for local dev. Set the same keys in the Vercel project settings.
# NOTE: Vite only exposes variables prefixed with VITE_ to the client bundle.

# Base URL of the API backend (Render). No trailing slash.
VITE_API_URL=http://localhost:3000

# Base URL of the public Astro site (used for "view live" cross-links).
VITE_PUBLIC_SITE_URL=http://localhost:4321
