---
import Layout from '../layouts/Layout.astro';
import Header from '../react-app/components/Header';
import Footer from '../react-app/components/Footer';
import Home from '../react-app/pages/Home';

// Fetch articles from our Fastify backend running on port 3000
let articles = [];
try {
  const response = await fetch(`${API_URL}/v1/articles`);
  if (response.ok) {
    articles = await response.json();
  }
} catch (e) {
  console.error("Failed to fetch articles:", e.message);
}
---

<Layout title="Unfilter Story | Authentic Startup & Tech News">
	<Header client:load />
	<Home client:load articles={articles} />
	<Footer client:load />
</Layout>
