---
import Layout from '../layouts/Layout.astro';
import Header from '../react-app/components/Header';
import Footer from '../react-app/components/Footer';
import AboutUs from '../react-app/pages/AboutUs';

let settings = {};
try {
  const res = await fetch(`${API_URL}/cms/v1/settings`);
  if (res.ok) {
    settings = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch settings:", e.message);
}

const aboutContent = settings.aboutUs || "";
---

<Layout title="About Us | Unfilter Story">
  <Header client:load />
  <AboutUs client:load content={aboutContent} />
  <Footer client:load />
</Layout>
