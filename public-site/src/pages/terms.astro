---
import Layout from '../layouts/Layout.astro';
import { API_URL } from '../lib/config.js';
import Header from '../react-app/components/Header';
import Footer from '../react-app/components/Footer';
import Terms from '../react-app/pages/Terms';

let settings = {};
try {
  const res = await fetch(`${API_URL}/cms/v1/settings`);
  if (res.ok) {
    settings = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch settings for terms:", e.message);
}

const termsContent = settings.termsAndConditions || "";
---

<Layout title="Terms and Conditions | Unfilter Story">
  <Header client:load />
  <Terms client:load content={termsContent} />
  <Footer client:load />
</Layout>
