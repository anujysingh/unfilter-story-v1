---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

let settings = {};
try {
  const res = await fetch('http://localhost:3000/cms/v1/settings');
  if (res.ok) {
    settings = await res.json();
  }
} catch (e) {
  // ignore
}

const termsContent = settings.termsAndConditions || `<p>Our terms and conditions are currently being updated. Please check back later.</p>`;
---

<Layout title="Terms and Conditions | Unfilter Story">
  <Header />
  
  <main class="flex-1 w-full max-w-4xl mx-auto px-4 md:px-8 py-16 lg:py-24">
    <div class="mb-12 border-b border-gray-100 pb-8">
      <h1 class="text-4xl md:text-5xl font-playfair font-black text-[#1A1A2E] mb-4">Terms and Conditions</h1>
      <p class="text-gray-500 font-inter">Last updated: {new Date().toLocaleDateString()}</p>
    </div>

    <div 
        class="prose prose-lg max-w-none font-inter text-gray-700"
        set:html={termsContent}
    />
  </main>

  <Footer />
</Layout>
