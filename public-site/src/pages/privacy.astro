---
import Layout from '../layouts/Layout.astro';
import { API_URL } from '../lib/config.js';
import Header from '../react-app/components/Header';
import Footer from '../react-app/components/Footer';
import Privacy from '../react-app/pages/Privacy';

let settings = {};
try {
  const res = await fetch(`${API_URL}/cms/v1/settings`);
  if (res.ok) {
    settings = await res.json();
  }
} catch (e) {
  console.error("Failed to fetch settings for privacy:", e.message);
}

const privacyContent = settings.privacyPolicy || "";
---

<Layout title="Privacy Policy | Unfilter Story">
  <Header client:load />
  <Privacy client:load content={privacyContent} />
  <Footer client:load />
</Layout>
