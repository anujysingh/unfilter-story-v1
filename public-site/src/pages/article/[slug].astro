---
import Layout from '../../layouts/Layout.astro';
import Header from '../../react-app/components/Header';
import Footer from '../../react-app/components/Footer';
import StoryDetail from '../../react-app/pages/StoryDetail';

const { slug } = Astro.params;

let article = null;
let relatedStories = [];
let errorMsg = null;

try {
  // Fetch the article details
  const response = await fetch(`http://localhost:3000/v1/articles/${slug}`);
  if (response.ok) {
    article = await response.json();
  } else {
    errorMsg = `Article "${slug}" could not be found (Status: ${response.status})`;
  }

  // Fetch other articles as related recommendations
  const allRes = await fetch('http://localhost:3000/v1/articles');
  if (allRes.ok) {
    const all = await allRes.json();
    relatedStories = all.filter(a => a.slug !== slug).slice(0, 3);
  }
} catch (e) {
  console.error("Failed to fetch article:", e.message);
  errorMsg = "Encountered an error trying to communicate with the backend. Is the API server running?";
}
---

<Layout title={article ? `${article.headline} | Unfilter Story` : 'Article Not Found | Unfilter Story'}>
  <Header client:load />

  {errorMsg && !article ? (
    <main class="flex-1 w-full max-w-4xl mx-auto px-4 md:px-8 py-24 text-center">
      <h1 class="text-3xl font-black text-[#111111] mb-4">404: Story Not Found</h1>
      <p class="text-gray-500 font-inter text-lg">{errorMsg}</p>
      <div class="mt-8">
        <a href="/" class="px-6 py-3 bg-gradient-to-r from-[#FF4D8D] to-[#FF7A18] text-white font-bold rounded-xl hover:shadow-lg transition-all">Return Home</a>
      </div>
    </main>
  ) : (
    <StoryDetail client:load article={article} relatedStories={relatedStories} />
  )}

  <Footer client:load />
</Layout>
