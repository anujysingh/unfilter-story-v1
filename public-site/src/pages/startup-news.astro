---
import Layout from '../layouts/Layout.astro';
import Header from '../react-app/components/Header';
import Footer from '../react-app/components/Footer';
import News from '../react-app/pages/News';

let newsItems = [];
try {
  // Fetch latest 20 RSS news items from the local backend
  const response = await fetch('http://localhost:3000/cms/v1/rss/fetch?limit=20');
  if (response.ok) {
    const data = await response.json();
    newsItems = data.items || [];
  }
} catch (e) {
  console.error("Failed to fetch RSS news:", e.message);
}
---

<Layout title="Startup News | Unfilter Story">
  <Header client:load />
  <News client:load newsItems={newsItems} />
  <Footer client:load />
</Layout>
