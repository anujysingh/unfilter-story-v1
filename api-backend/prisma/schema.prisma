generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CmsUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  role          String
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  bio           String?
  avatarUrl     String?   @map("avatar_url")
  designation   String?
  twitterUrl    String?   @map("twitter_url")
  linkedinUrl   String?   @map("linkedin_url")
  isActive      Boolean   @default(true) @map("is_active")
  twoFaSecret   String?   @map("two_fa_secret")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  primaryArticles Article[]        @relation("PrimaryAuthor")
  articleAuthors  ArticleAuthor[]
  articleVersions ArticleVersion[]
  media           Media[]
  auditLogs       AuditLog[]

  @@map("cms_users")
}

model Category {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  description      String?
  parentId         String?    @map("parent_id")
  featuredImageUrl String?    @map("featured_image_url")
  displayOrder     Int        @default(0) @map("display_order")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")

  parent           Category?  @relation("ParentChildren", fields: [parentId], references: [id])
  children         Category[] @relation("ParentChildren")
  articles         Article[]

  @@map("categories")
}

model Tag {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now()) @map("created_at")

  articleTags ArticleTag[]

  @@map("tags")
}

model Article {
  id               String       @id @default(uuid())
  headline         String
  subHeadline      String?      @map("sub_headline")
  slug             String       @unique
  body             String
  featuredImageUrl String?      @map("featured_image_url")
  imageCaption     String?      @map("image_caption")
  imageCredit      String?      @map("image_credit")
  categoryId       String?      @map("category_id")
  primaryAuthorId  String?      @map("primary_author_id")
  status           String       @default("draft")
  articleType      String       @default("standard") @map("article_type")
  accessLevel      String       @default("free") @map("access_level")
  isBreakingNews   Boolean      @default(false) @map("is_breaking_news")
  allowComments    Boolean      @default(true) @map("allow_comments")
  seoTitle         String?      @map("seo_title")
  seoDescription   String?      @map("seo_description")
  socialImageUrl   String?      @map("social_image_url")
  readingTimeMins  Int?         @map("reading_time_mins")
  viewCount        Int          @default(0) @map("view_count")
  scheduledAt      DateTime?    @map("scheduled_at")
  publishedAt      DateTime?    @map("published_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  category         Category?    @relation(fields: [categoryId], references: [id])
  primaryAuthor    CmsUser?     @relation("PrimaryAuthor", fields: [primaryAuthorId], references: [id])
  
  articleTags      ArticleTag[]
  articleAuthors   ArticleAuthor[]
  versions         ArticleVersion[]

  @@map("articles")
}

model ArticleTag {
  articleId String  @map("article_id")
  tagId     String  @map("tag_id")

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model ArticleAuthor {
  articleId String  @map("article_id")
  authorId  String  @map("author_id")
  role      String  @default("co_author")

  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author    CmsUser @relation(fields: [authorId], references: [id])

  @@id([articleId, authorId])
  @@map("article_authors")
}

model ArticleVersion {
  id        String   @id @default(uuid())
  articleId String   @map("article_id")
  savedById String?  @map("saved_by")
  headline  String?
  body      String?
  createdAt DateTime @default(now()) @map("created_at")

  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  savedBy   CmsUser? @relation(fields: [savedById], references: [id])

  @@map("article_versions")
}

model Media {
  id         String   @id @default(uuid())
  filename   String
  url        String
  mimeType   String?  @map("mime_type")
  sizeBytes  Int?     @map("size_bytes")
  folder     String?
  uploadedById String? @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  uploadedBy CmsUser? @relation(fields: [uploadedById], references: [id])

  @@map("media")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   String?
  createdAt  DateTime @default(now()) @map("created_at")

  user       CmsUser? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Redirect {
  id           String   @id @default(uuid())
  fromPath     String   @unique @map("from_path")
  toPath       String   @map("to_path")
  redirectType Int      @default(301) @map("redirect_type")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("redirects")
}

model Navigation {
  id           String    @id @default(uuid())
  label        String
  href         String
  displayOrder Int       @default(0) @map("display_order")
  parentId     String?   @map("parent_id")
  type         String    @default("link") // "link", "dropdown", "category_group"
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  parent       Navigation? @relation("NavigationHierarchy", fields: [parentId], references: [id])
  children     Navigation[] @relation("NavigationHierarchy")

  @@map("navigation")
}

model RssSource {
  id        String   @id @default(uuid())
  name      String
  url       String   @unique
  logoUrl   String?  @map("logo_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("rss_sources")
}

model DiscoveryCache {
  id          String   @id @default(uuid())
  title       String
  link        String   @unique
  pubDate     DateTime
  content     String?
  author      String?
  source      String
  logoUrl     String?  @map("logo_url")
  categories    String?  // JSON stringified array
  isImported    Boolean  @default(false) @map("is_imported")
  isBookmarked  Boolean  @default(false) @map("is_bookmarked")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([pubDate])
  @@map("discovery_cache")
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  label     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}
