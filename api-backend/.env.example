# Environment Variables for Unfilter Story API Backend

# Database Configuration
# Use your own connection string. For Neon, copy it from the dashboard.
# NEVER commit a real credential here — this file is tracked in git.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Application Settings
PORT=3000
NODE_ENV="development"

# Security
# Run `openssl rand -base64 32` to generate a strong secret
JWT_SECRET="generate-a-strong-jwt-secret-for-production"

# Comma-separated list of allowed frontend origins for CORS.
# Leave unset for local dev (allows all). Set in production, e.g.:
# ALLOWED_ORIGINS="https://unfilter-story-v1.vercel.app,https://unfilter-admin-cms.vercel.app"
# ALLOWED_ORIGINS=

# External API Keys (Future)
# CLOUDFLARE_R2_ACCESS_KEY=
# CLOUDFLARE_R2_SECRET_KEY=
# CLOUDFLARE_R2_BUCKET=
